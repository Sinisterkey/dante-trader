# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# ==================== MetaTrader 5 ====================
MT5_LOGIN=12345678
MT5_PASSWORD=password
MT5_SERVER=MetaQuotes-Demo

# ==================== Telegram ====================
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ==================== Webhook Security ====================
WEBHOOK_SECRET=your_webhook_secret_key_min_32_chars

# ==================== Trading Configuration ====================
RISK_PER_TRADE=0.02
MIN_REWARD_RATIO=2.0
MAX_CONCURRENT_POSITIONS=3
ACCOUNT_BALANCE=10000

# ==================== Agent Weights ====================
CHART_AGENT_WEIGHT=0.40
NEWS_AGENT_WEIGHT=0.30
MEMORY_AGENT_WEIGHT=0.30

# ==================== Decision Thresholds ====================
STRONG_SIGNAL_THRESHOLD=75
WEAK_SIGNAL_THRESHOLD=50
AVOID_SIGNAL_THRESHOLD=25

# ==================== Technical Indicators ====================
SR_LOOKBACK_CANDLES=50
TREND_SMA_FAST=50
TREND_SMA_SLOW=200
ATR_PERIOD=14
ATR_MULTIPLIER=2.0

# ==================== API Server ====================
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# ==================== Database ====================
DB_PATH=data/trades.db

# ==================== Logging ====================
LOG_LEVEL=INFO
